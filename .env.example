# ================================================================
# LaplaceSignal — 环境变量示例
# 复制此文件为 .env 并填入真实密钥
# ================================================================

# OKX API 凭证（主账号 / 只读 + 交易权限）
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_API_PASSPHRASE=your_okx_api_passphrase_here

# Tavily 搜索 API（新闻情绪因子）
TAVILY_KEY=your_tavily_api_key_here

# 可选：Telegram 通知
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 可选：运行模式 (live / paper)
RUN_MODE=paper
